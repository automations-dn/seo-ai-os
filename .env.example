# ============================================================
# SEO AI OS — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control. It is in .gitignore ✓
#
# HOW THIS SYSTEM WORKS:
# You are running this via Claude Code (web or desktop) by cloning
# this GitHub repo. Claude Code handles all AI/LLM intelligence —
# NO Anthropic API key is needed here. Claude Code is already
# authenticated via your Anthropic subscription.
# ============================================================

# -------------------------------------------------------
# REQUIRED FOR RANKINGS & TRAFFIC DATA
# Connect these to unlock /monthly_report and /audit GSC data
# -------------------------------------------------------

# Google Search Console + GA4 (Free — requires OAuth setup)
# Setup guide: https://developers.google.com/webmaster-tools/search-console-api/v1/configure
GOOGLE_CLIENT_ID=39378431989-f4hfd0bsskbcrtkudgd4ui7m9g447v9m.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_PROJECT_ID=seo-ai-os-data

# Google PageSpeed Insights API (Free — simple API key, no OAuth needed)
# Enables Core Web Vitals (LCP, INP, CLS) scores in /audit and /page reports
# How to get: console.cloud.google.com → Credentials → + Create Credentials → API Key
# Then enable "PageSpeed Insights API" in APIs & Services → Library
GOOGLE_API_KEY=AIzaSyDwznCFpcMeqlpX8-z_CvrAQSEe2R0Pjx4

# -------------------------------------------------------
# OPTIONAL — ENHANCES SPECIFIC FEATURES
# -------------------------------------------------------

# Hunter.io — Used by /link_building to find contact emails
# Free tier: 25 lookups/month | https://hunter.io
HUNTER_API_KEY=e42e160b14f099d8dc18c797ed6823a7e7031805

# -------------------------------------------------------
# OUTPUT SETTINGS
# -------------------------------------------------------

# Where should reports be saved?
# Options: "local" (saves to clients/reportss/) | "google_drive"
REPORT_OUTPUT=local

# Only needed if REPORT_OUTPUT=google_drive
GOOGLE_DRIVE_FOLDER_ID=

# -------------------------------------------------------
# OPTIONAL — PROXY (for avoiding Google rate limits on scrapers)
# -------------------------------------------------------
PROXY_URL=

# -------------------------------------------------------
# DATAFORSEO API — Enterprise Keyword & SERP Data
# Required for /audit, /competitor_gap, /keyword_research
# Sign up: https://dataforseo.com/apis
# Pricing: Pay-as-you-go (~$0.001 per SERP, $0.003 per domain)
# -------------------------------------------------------
DATAFORSEO_LOGIN=your_dataforseo_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_password
