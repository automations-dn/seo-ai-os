# ============================================================
# SEO AI OS — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control. It is in .gitignore ✓
#
# HOW THIS SYSTEM WORKS:
# You are running this via Claude Code (web or desktop) by cloning
# this GitHub repo. Claude Code handles all AI/LLM intelligence —
# NO Anthropic API key is needed here. Claude Code is already
# authenticated via your Anthropic subscription.
# ============================================================

# -------------------------------------------------------
# REQUIRED FOR RANKINGS & TRAFFIC DATA
# Connect these to unlock /monthly_report and /audit GSC data
# -------------------------------------------------------

# Google Search Console + GA4 (Free — requires OAuth setup)
# Setup guide: https://developers.google.com/webmaster-tools/search-console-api/v1/configure
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PROJECT_ID=

# -------------------------------------------------------
# OPTIONAL — ENHANCES SPECIFIC FEATURES
# -------------------------------------------------------

# Hunter.io — Used by /link_building to find contact emails
# Free tier: 25 lookups/month | https://hunter.io
HUNTER_API_KEY=

# -------------------------------------------------------
# OUTPUT SETTINGS
# -------------------------------------------------------

# Where should reports be saved?
# Options: "local" (saves to clients/reportss/) | "google_drive"
REPORT_OUTPUT=local

# Only needed if REPORT_OUTPUT=google_drive
GOOGLE_DRIVE_FOLDER_ID=

# -------------------------------------------------------
# OPTIONAL — PROXY (for avoiding Google rate limits on scrapers)
# -------------------------------------------------------
PROXY_URL=
